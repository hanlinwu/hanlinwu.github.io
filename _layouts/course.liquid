---
layout: page
---
<style>
  /* Hero banner with image */
  .course-hero {
    position: relative;
    width: 100%;
    height: 220px;
    margin-bottom: 2.5rem;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }
  .course-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }


  /* Course info card */
  .course-info {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    padding: 1rem 1.25rem;
    margin-bottom: 2.5rem;
    border-left: 4px solid var(--global-theme-color);
    background-color: var(--global-card-bg-color);
    border-radius: 0 6px 6px 0;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
  }
  .course-info p {
    margin: 0;
    font-size: 0.95rem;
  }
  .course-info .info-icon {
    margin-right: 0.35rem;
    color: var(--global-theme-color);
    width: 1em;
    text-align: center;
  }

  /* Section spacing */
  .course h2 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .course h2:first-of-type {
    margin-top: 0;
  }

  /* Table */
  .course table {
    border-collapse: collapse !important;
    width: 100% !important;
    border: 1px solid #dee2e6 !important;
    font-size: 0.95rem;
  }
  .course table th,
  .course table td {
    border: 1px solid #dee2e6 !important;
    padding: 10px 14px !important;
    vertical-align: middle;
  }
  .course table thead th {
    background-color: var(--global-theme-color) !important;
    color: #fff !important;
    font-weight: 600;
    text-align: center;
  }
  .course table tbody tr:hover {
    background-color: rgba(0, 0, 0, 0.02);
  }
  html[data-theme="dark"] .course table {
    border-color: #424246 !important;
  }
  html[data-theme="dark"] .course table th,
  html[data-theme="dark"] .course table td {
    border-color: #424246 !important;
  }
  html[data-theme="dark"] .course table tbody tr:hover {
    background-color: rgba(255, 255, 255, 0.03);
  }

  @media (max-width: 768px) {
    .course-hero {
      height: 160px;
    }
    .course-hero .hero-overlay {
      padding: 1.25rem 1.5rem;
    }
    .course-hero .hero-overlay h2 {
      font-size: 1.25rem;
    }
  }
</style>
<div class="course">

  {% if page.course_image %}
    <div class="course-hero">
      <img src="{{ page.course_image | relative_url }}" alt="{{ page.title }}">
    </div>
  {% endif %}

  {% if page.term or page.location or page.time %}
    <div class="course-info">
      {% if page.term %}
        <p><i class="fa-solid fa-calendar info-icon"></i><strong>学期：</strong>{{ page.term }}</p>
      {% endif %}

      {% if page.location %}
        <p><i class="fa-solid fa-location-dot info-icon"></i><strong>上课地点：</strong>{{ page.location }}</p>
      {% endif %}

      {% if page.time %}
        <p><i class="fa-solid fa-clock info-icon"></i><strong>上课时间：</strong>{{ page.time }}</p>
      {% endif %}
    </div>
  {% endif %}

  {{ content }}

  {% if page.schedule %}
    <h2>课程安排</h2>
    <table class="table table-sm table-bordered">
      <thead>
        <tr>
          <th>周次</th>
          <th>日期</th>
          <th>主题</th>
          <th>资料</th>
        </tr>
      </thead>
      <tbody>
        {% for entry in page.schedule %}
          <tr>
            <td>{{ entry.week }}</td>
            <td>{{ entry.date }}</td>
            <td>
              {% if entry.topic %}
                <strong>{{ entry.topic }}</strong>
              {% endif %}
              {% if entry.description %}
                <div class="schedule-description">{{ entry.description | markdownify }}</div>
              {% endif %}
            </td>
            <td>
              {% if entry.materials %}
                <ul class="schedule-materials">
                  {% for material in entry.materials %}
                    <li>
                      {% if material.url %}
                        {% if material.url contains '://' %}
                          <a href="{{ material.url }}" target="_blank">{{ material.name }}</a>
                        {% else %}
                          <a href="{{ material.url | relative_url }}" target="_blank">{{ material.name }}</a>
                        {% endif %}
                      {% else %}
                        {{ material.name }}
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
</div>
